import java.util.*;
class Solution {
    public static String longestCommonPrefix(String[] strs) {
        if(strs.length == 0 )return "";

        String fix = strs[0];
        for(int i = 1 ; i<strs.length;i++){
           
// strs[i].indexOf(prefix) searches inside strs[i] for the substring prefix
// 0 → if prefix is found starting at the first character (means it’s a prefix).
// > 0 → if prefix is found, but not at the start (so it’s not a prefix).
// -1 → if prefix is not found at all.
            while(strs[i].indexOf(fix)!=0){
             fix = fix.substring(0,fix.length()-1);
             if (fix.isEmpty()) return ""; 
            }
        }
        return fix;
    }

    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);

       
        int n = sc.nextInt();
        sc.nextLine(); 
        String[] strs = new String[n];
        for (int i = 0; i < n; i++) {
            strs[i] = sc.nextLine();
        }

        System.out.println( longestCommonPrefix(strs));
    }
}
