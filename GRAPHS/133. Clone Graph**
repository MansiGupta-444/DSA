class Solution {
    public Node cloneGraph(Node node) {
        
        // Edge case: if input graph is empty
        if (node == null) return null;

        // HashMap to store mapping:
        // original node → cloned node
        HashMap<Node, Node> hm = new HashMap<>();

        // Queue for BFS traversal (stores original nodes)
        Queue<Node> q = new LinkedList<>();

        // Step 1: Create clone of starting node
        Node clone = new Node(node.val);

        // Store mapping of original → clone
        hm.put(node, clone);

        // Add original node to queue to start BFS
        q.add(node);

        // Step 2: BFS traversal of original graph
        while (!q.isEmpty()) {

            // Take one node from queue (original graph)
            Node curr = q.remove();

            // Traverse all neighbors of current node
            for (int i = 0; i < curr.neighbors.size(); i++) {

                // Get neighbor from original graph
                Node ng = curr.neighbors.get(i);

                // If this neighbor is not yet cloned
                if (!hm.containsKey(ng)) {

                    // Create its clone
                    Node newnode = new Node(ng.val);

                    // Store mapping: original → clone
                    hm.put(ng, newnode);

                    // Add original neighbor to queue for further traversal
                    q.add(ng);
                }

                // Step 3: Connect cloned nodes
                // IMPORTANT:
                // We connect clone(curr) → clone(neighbor)
                // NOT original nodes
                hm.get(curr).neighbors.add(hm.get(ng));
            }
        }

        // Return clone of starting node
        // (this represents the entire cloned graph)
        return clone;
    }
}
